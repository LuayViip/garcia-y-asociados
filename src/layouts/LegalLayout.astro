---
// Shared shell for the three legal pages: same dark system, centered document measure, noindex.
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import DoubleRule from '../components/DoubleRule.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  heading: string;
}

const { title, description, path, heading } = Astro.props;
---

<Base title={title} description={description} path={path} noindex>
  <Header />
  <main class="legal">
    <div class="container legal__measure">
      <h1 class="legal__title">{heading}</h1>
      <DoubleRule />
      <div class="legal-content">
        <slot />
      </div>
    </div>
  </main>
  <Footer />
  <WhatsAppButton />
</Base>

<style>
  .legal {
    padding-block-start: calc(var(--space-hero) * 0.6);
    padding-block-end: var(--space-section);
  }

  .legal__measure {
    max-width: 680px;
  }

  .legal__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 3rem);
    font-weight: 400;
    color: var(--color-ivory);
    margin-bottom: 32px;
  }

  .legal-content {
    margin-top: 64px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .legal-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 400;
    color: var(--color-ivory);
    margin-bottom: 16px;
  }

  .legal-content :global(p) {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-stone);
  }

  .legal-content :global(p + p) {
    margin-top: 16px;
  }

  .legal-content :global(a) {
    color: var(--color-burdeos-light);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
